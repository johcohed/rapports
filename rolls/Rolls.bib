@article{couvreuxWatervapourVariabilityConvective2005b,
  title = {Water‐vapour Variability within a Convective Boundary‐layer Assessed by Large‐eddy Simulations and {{IHOP}}\_2002 Observations},
  author = {Couvreux, F. and Guichard, F. and Redelsperger, J.‐L. and Kiemle, C. and Masson, V. and Lafore, J.‐P. and Flamant, C.},
