@article{gronemeierEffectsUnstableStratification2017,
  title = {Effects of {{Unstable Stratification}} on {{Ventilation}} in {{Hong Kong}}},
  author = {Gronemeier, Tobias and Raasch, Siegfried and Ng, Edward},
  date = {2017-09-08},
  journaltitle = {Atmosphere},
  shortjournal = {Atmosphere},
  volume = {8},
  number = {9},
  pages = {168},
  issn = {2073-4433},
  doi = {10.3390/atmos8090168},
  url = {https://www.mdpi.com/2073-4433/8/9/168},
  urldate = {2025-11-18},
  abstract = {Ventilation in cities is crucial for the well being of their inhabitants. Therefore, local governments require air ventilation assessments (AVAs) prior to the construction of new buildings. In a standard AVA, however, only neutral stratification is considered, although diabatic and particularly unstable conditions may be observed more frequently in nature. The results presented here indicate significant changes in ventilation within most of the area of Kowloon City, Hong Kong, included in the study. A new definition for calculating ventilation was introduced, and used to compare the influence of buildings on ventilation under conditions of neutral and unstable stratification. The overall ventilation increased due to enhanced vertical mixing. In the vicinity of exposed buildings, however, ventilation was weaker for unstable stratification than for neutral stratification. The influence on ventilation by building parameters, such as the plan area index, was altered when unstable stratification was considered. Consequently, differences in stratification were shown to have marked effects on ventilation estimates, which should be taken into consideration in future AVAs.},
  langid = {english},
  file = {/home/johanhedman/Zotero/storage/R8R7GV3A/Gronemeier et al. - 2017 - Effects of Unstable Stratification on Ventilation in Hong Kong.pdf}
}

@article{grossmanAnalysisVerticalVelocity1982,
